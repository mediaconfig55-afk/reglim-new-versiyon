{
  "expo": {
    "name": "Reglim & Takvim",
    "slug": "reglim-takvim",
    "version": "2.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reglim-takvim",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.regliyiz.app"
    },
    "android": {
      "package": "com.regliyiz.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 58,
      "adaptiveIcon": {
        "backgroundColor": "#121214",
        "foregroundImage": "./assets/images/icon.png"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain"
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-localization",
      "expo-sharing",
      "expo-local-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.393754770159-37gitini3bo06i37vk1bjmmaup3qicrt"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF2366"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b263c72-f62c-483f-a6ab-c23beb809ae7"
      }
    },
    "owner": "takvim"
  }
}
